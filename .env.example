# =============================================================================
# HYDRO — Vercel proyecto «hydronet» + Prisma Postgres (Storage)
# Store de ejemplo: prisma-postgres-aquamarine-engine
# Dominio: https://hydronet.live
# =============================================================================
# En Vercel: Storage → Prisma Postgres → Connect → suele enlazar DATABASE_URL al proyecto.
# Copie estas claves en Settings → Environment Variables → Production y haga Redeploy.

# Cadena que entrega Prisma Postgres (o Postgres compatible). Obligatoria para la app y para la CLI.
DATABASE_URL=

# NextAuth v5 — generar: openssl rand -base64 32
AUTH_SECRET=

# URL pública del sitio (sin barra final)
AUTH_URL=https://hydronet.live
NEXTAUTH_URL=https://hydronet.live

NEXT_PUBLIC_SITE_URL=https://hydronet.live

# --- Sincronizar esquema con la base real (desde tu máquina, con DATABASE_URL apuntando al mismo store) ---
# Producción con historial de migraciones:
#   npx prisma migrate deploy
# Prototipo / igualar schema sin historial (usar con cuidado en prod):
#   npx prisma db push
